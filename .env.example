# Copy this file to .env for local experiments.
# Do not commit real endpoints, account IDs, tenant IDs, API keys, or connection strings.

APP_ENV=local
AWS_REGION=us-east-1

# Azure source environment. Assumes these resources already exist.
AZURE_OPENAI_BASE_URL=https://<azure-openai-resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_DEPLOYMENT=<azure-openai-deployment>
AZURE_OPENAI_API_KEY=<use-key-vault-or-local-secret>
AZURE_AI_SEARCH_ENDPOINT=https://<azure-search-service>.search.windows.net
AZURE_AI_SEARCH_INDEX=policy-sections
AZURE_BLOB_POLICY_CONTAINER=policies
AZURE_COSMOS_DATABASE=erp-governance

# AWS target environment.
AWS_RESOURCE_PREFIX=erpgov-migration
AWS_S3_POLICY_BUCKET=<policy-bucket-name>
AWS_S3_POLICY_PREFIX=policies
AWS_OPENSEARCH_ENDPOINT=https://<opensearch-serverless-endpoint>
AWS_OPENSEARCH_INDEX=policy-sections
AWS_DYNAMODB_REQUESTS_TABLE=erpgov-migration-requests
AWS_DYNAMODB_AUDIT_EVENTS_TABLE=erpgov-migration-audit-events
AWS_DYNAMODB_VENDORS_TABLE=erpgov-migration-vendors
AWS_DYNAMODB_APPROVAL_MATRIX_TABLE=erpgov-migration-approval-matrix

# GPT-5.4/GPT-5.5 use Bedrock Mantle with the Responses API.
# GPT-OSS models may use Bedrock Runtime Converse/Invoke where supported.
AWS_BEDROCK_API_MODE=responses
AWS_BEDROCK_MODEL_ID=openai.gpt-5.4
AWS_BEDROCK_MAX_TOKENS=700
AWS_BEARER_TOKEN_BEDROCK=<use-secrets-manager-or-local-secret>
